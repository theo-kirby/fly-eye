# Optional override for the Flywheel base URL.
# Defaults to https://flywheel.paradigma.inc/api when unset.
# VITE_FLYWHEEL_BASE_URL=https://flywheel.paradigma.inc/api

# Optional API key for local dev. If set, the app uses it instead of
# prompting. Must use the VITE_ prefix or Vite won't expose it to the browser.
# VITE_FLYWHEEL_API_KEY=fwk_...
